DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/menu_digital
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=menu_digital

JWT_SECRET_KEY=change-me-dev-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720

# Genera con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

PAYMENT_MODE=stub
TILOPAY_API_BASE_URL=https://sandbox-api.tilopay.com

# Client ID de Google OAuth (tipo "Web application" en Google Cloud Console).
# Un solo Client ID para toda la plataforma, no uno por restaurante. Si se
# deja vacío, el botón de Sign-In con Google simplemente no aparece.
GOOGLE_CLIENT_ID=

CORS_ORIGINS=["http://localhost:5173"]

ENV=development
SEED_ADMIN_PASSWORD=devpassword123
